# Cue Landing — Environment Variables
#
# Copy this file to `.env` (do NOT commit .env) and fill in your values.
# Scripts in scripts/ load these via dotenv or process.env.

# ── Vertex AI (required for translate.mjs and blog-write.mjs) ─────────────
# Your Google Cloud project ID with Vertex AI API enabled.
# Get one at https://console.cloud.google.com/projectselector2/home/dashboard
# Or ask Oscar for access to the Sophon-LLC cue-ai-desktop project.
VERTEX_PROJECT=your-gcp-project-id

# Region for Vertex AI endpoints (us-central1 is default).
VERTEX_LOCATION=us-central1

# ── Google Cloud ADC (required for Vertex AI) ─────────────────────────────
# Option A (recommended): Run `gcloud auth application-default login`
#   → credentials stored at ~/.config/gcloud/application_default_credentials.json
#   → scripts auto-detect, no env var needed.
#
# Option B: Service account JSON file path.
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Cloudflare Pages (only needed for local `wrangler pages deploy`) ──────
# Most contributors don't need this — maintainers deploy via CI.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# ── IndexNow (already configured, key file is public) ─────────────────────
# The key file at /70bdb037c70ca796905176093dc82599.txt is committed and public.
# No env var needed — scripts read the key from the URL.
